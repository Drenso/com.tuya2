{
  "triggers": [
    {
      "id": "spa_heat_state_changed",
      "$filter": "capabilities=spa_heat_state",
      "title": {
        "en": "Heating status changed",
        "nl": "Verwarmingsstatus gewijzigd"
      },
      "tokens": [
        {
          "name": "state",
          "type": "string",
          "title": { "en": "Status", "nl": "Status" },
          "example": { "en": "heat" }
        }
      ]
    },
    {
      "id": "spa_fault_occurred",
      "$filter": "capabilities=fault",
      "title": {
        "en": "An error occurred",
        "nl": "Er is een fout opgetreden"
      },
      "tokens": [
        {
          "name": "error",
          "type": "string",
          "title": { "en": "Error", "nl": "Fout" },
          "example": { "en": "No or insufficient water flow (E90)" }
        },
        {
          "name": "code",
          "type": "string",
          "title": { "en": "Error code", "nl": "Foutcode" },
          "example": { "en": "190" }
        }
      ]
    },
    {
      "id": "spa_fault_cleared",
      "$filter": "capabilities=fault",
      "title": {
        "en": "All errors cleared",
        "nl": "Alle fouten verholpen"
      }
    }
  ],
  "conditions": [
    {
      "id": "spa_heater_is_on",
      "$filter": "capabilities=onoff.heater",
      "title": {
        "en": "Heater is !{{on|off}}",
        "nl": "Verwarming is !{{aan|uit}}"
      }
    },
    {
      "id": "spa_bubble_is_on",
      "$filter": "capabilities=onoff.bubble",
      "title": {
        "en": "Bubbles are !{{on|off}}",
        "nl": "Bubbels zijn !{{aan|uit}}"
      }
    },
    {
      "id": "spa_filter_is_on",
      "$filter": "capabilities=onoff.filter",
      "title": {
        "en": "Filter pump is !{{on|off}}",
        "nl": "Filterpomp is !{{aan|uit}}"
      }
    },
    {
      "id": "spa_has_fault",
      "$filter": "capabilities=fault",
      "title": {
        "en": "An error !{{is|is not}} active",
        "nl": "Er is !{{wel|geen}} fout actief"
      }
    },
    {
      "id": "spa_heat_state_is",
      "$filter": "capabilities=spa_heat_state",
      "title": {
        "en": "Heating status !{{is|is not}} [[state]]",
        "nl": "Verwarmingsstatus !{{is|is niet}} [[state]]"
      },
      "titleFormatted": {
        "en": "Heating status !{{is|is not}} [[state]]",
        "nl": "Verwarmingsstatus !{{is|is niet}} [[state]]"
      },
      "args": [
        {
          "name": "state",
          "type": "dropdown",
          "title": { "en": "Status", "nl": "Status" },
          "values": [
            { "id": "off", "title": { "en": "Off", "nl": "Uit" } },
            { "id": "heat", "title": { "en": "Heating", "nl": "Verwarmen" } },
            { "id": "warm", "title": { "en": "Warm", "nl": "Warm" } },
            { "id": "warmflash", "title": { "en": "Keeping warm", "nl": "Warmhouden" } }
          ]
        }
      ]
    }
  ],
  "actions": [
    {
      "id": "spa_set_heater",
      "$filter": "capabilities=onoff.heater",
      "title": {
        "en": "Set heater",
        "nl": "Verwarming instellen"
      },
      "titleFormatted": {
        "en": "Set heater [[value]]",
        "nl": "Verwarming [[value]]"
      },
      "args": [
        {
          "name": "value",
          "type": "checkbox",
          "title": { "en": "Value", "nl": "Waarde" }
        }
      ]
    },
    {
      "id": "spa_set_bubble",
      "$filter": "capabilities=onoff.bubble",
      "title": {
        "en": "Set bubbles",
        "nl": "Bubbels instellen"
      },
      "titleFormatted": {
        "en": "Set bubbles [[value]]",
        "nl": "Bubbels [[value]]"
      },
      "args": [
        {
          "name": "value",
          "type": "checkbox",
          "title": { "en": "Value", "nl": "Waarde" }
        }
      ]
    },
    {
      "id": "spa_set_filter",
      "$filter": "capabilities=onoff.filter",
      "title": {
        "en": "Set filter pump",
        "nl": "Filterpomp instellen"
      },
      "titleFormatted": {
        "en": "Set filter pump [[value]]",
        "nl": "Filterpomp [[value]]"
      },
      "args": [
        {
          "name": "value",
          "type": "checkbox",
          "title": { "en": "Value", "nl": "Waarde" }
        }
      ]
    }
  ]
}
